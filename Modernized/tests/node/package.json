{
  "name": "spring-music-api-tests",
  "version": "1.0.0",
  "description": "API contract tests for Spring Music",
  "scripts": {
    "test": "jest --runInBand --forceExit",
    "test:verbose": "jest --runInBand --forceExit --verbose"
  },
  "dependencies": {
    "axios": "^1.7.2"
  },
  "devDependencies": {
    "jest": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.js"],
    "testTimeout": 15000
  }
}
